{
  "name": "Memory Update",
  "description": "Обновление памяти клиента через webhook",
  "nodes": [
    {
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "parameters": {
        "path": "memory-update",
        "httpMethod": "POST"
      },
      "position": [200, 300]
    },
    {
      "name": "Upsert Memory",
      "type": "n8n-nodes-base.supabase",
      "parameters": {
        "operation": "create",
        "tableId": "client_memory",
        "fields": {
          "client_id": "={{ $json.client_id }}",
          "market_id": "={{ $json.market_id }}",
          "key": "={{ $json.key }}",
          "value": "={{ $json.value }}",
          "importance": "={{ $json.importance || 5 }}"
        }
      },
      "position": [400, 300]
    },
    {
      "name": "Log Action",
      "type": "n8n-nodes-base.supabase",
      "parameters": {
        "operation": "create",
        "tableId": "action_history",
        "fields": {
          "market_id": "={{ $json.market_id }}",
          "actor_type": "n8n",
          "action": "update_memory",
          "entity_type": "client_memory",
          "payload": "={{ JSON.stringify($json) }}"
        }
      },
      "position": [600, 300]
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "Upsert Memory", "type": "main", "index": 0 }]]
    },
    "Upsert Memory": {
      "main": [[{ "node": "Log Action", "type": "main", "index": 0 }]]
    }
  }
}