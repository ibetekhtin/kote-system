# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://cmmdrhususjuadqzyssc.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.cmmdrhususjuadqzyssc.supabase.co:5432/postgres

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here
MANAGER_CHAT_ID=your_chat_id_here

# ─── Gemini AI ─────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── n8n (локальный) ──────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_HOST=http://localhost:5678

# ─── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000

# ─── Monitoring ────────────────────────────────────────────────
# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=

# ─── AWS S3 (optional, for backup upload) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

