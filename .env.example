# ═══════════════════════════════════════════════════════════════
# KOTЭ SYSTEM — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://cmmdrhususjuadqzyssc.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_DB_URL=postgresql://postgres:password@db.cmmdrhususjuadqzyssc.supabase.co:5432/postgres

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here
MANAGER_CHAT_ID=your_chat_id_here

# ─── AI Fallback Chain: AITUNNEL → Groq → OpenRouter → Gemini ──
#
# Порядок вызова:
#   1. AITUNNEL  — основной (российский, 600₽ на балансе, 216+ моделей)
#   2. Groq      — запасной (бесплатный, ultra-fast)
#   3. OpenRouter — третий (международный агрегатор)
#   4. Gemini    — аварийный (бесплатный, прямой API Google)

# 1. AITUNNEL (основной) — aitunnel.ru
AITUNNEL_API_KEY=your_aitunnel_api_key_here
AITUNNEL_MODEL=gemini-2.5-flash
# Доступные модели: gemini-2.5-flash, gpt-4o-mini, deepseek-chat, claude-haiku-4.5

# 2. Groq (запасной) — console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# 3. OpenRouter (третий) — openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# 4. Gemini (аварийный) — aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── n8n (локальный) ──────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_HOST=http://localhost:5678

# ─── Backend ───────────────────────────────────────────────────
BACKEND_PORT=8000

# ─── Monitoring ────────────────────────────────────────────────
# Optional: Slack webhook for alerts
SLACK_WEBHOOK_URL=

# ─── AWS S3 (optional, for backup upload) ─────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ─── Bot (Python, disabled) ───────────────────────────────────
# Для включения: docker compose --profile bot up -d
# СНАЧАЛА остановить n8n Cloud workflow!
WEBHOOK_URL=https://nestandart.online
BOT_PORT=8081