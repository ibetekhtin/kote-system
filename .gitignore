# Secrets — broad coverage so stray .env variants can never be committed
.env
.env.local
.env*
!.env.example
*.save

# Git bundles / archives accidentally dropped in the tree
*.bundle
*.tar.gz

# Dependencies
node_modules/
venv/
.venv/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/
backups/

# Docker
docker-compose.override.yml

# IDE
.vscode/
.idea/

